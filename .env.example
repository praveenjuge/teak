# Development Environment Variables
NODE_ENV=development
FRONTEND_PORT=3000
BACKEND_PORT=3001

# Production Environment Variables (for docker-compose.yml)
PORT=3000

# PostgreSQL Database Configuration
POSTGRES_DB=teak_db
POSTGRES_USER=teak_user
POSTGRES_PASSWORD=teak_db_password

# Database Connection URL (for application use)
DATABASE_URL=postgresql://teak_user:teak_db_password@localhost:5432/teak_db

# Better Auth Configuration
BETTER_AUTH_SECRET=your_secure_secret_here_at_least_32_characters_long
BETTER_AUTH_URL=http://localhost:3000

# Add any other environment variables your app needs
# JWT_SECRET=your-super-secret-jwt-key
# API_KEY=your-api-key
