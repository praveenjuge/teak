{
  "name": "teak",
  "version": "1.0.46",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:raycast": "turbo run build --filter=./apps/raycast",
    "build:extension": "turbo run build --filter=@teak/extension",
    "dev": "turbo watch dev --filter=@teak/web --filter=@teak/convex --filter=@teak/api --filter=@teak/desktop --filter=./apps/raycast --filter=@teak/docs --filter=@teak/extension",
    "dev:all": "turbo watch dev",
    "dev:convex": "turbo watch dev --filter=@teak/convex",
    "dev:docs": "turbo watch dev --filter=@teak/docs",
    "dev:api": "turbo watch dev --filter=@teak/api",
    "dev:raycast": "turbo watch dev --filter=./apps/raycast",
    "publish:raycast": "cd apps/raycast && bun run publish",
    "dev:extension": "turbo watch dev --filter=@teak/extension --filter=@teak/convex",
    "dev:mobile": "turbo watch dev --filter=@teak/mobile",
    "dev:web": "turbo watch dev --filter=@teak/web --filter=@teak/convex",
    "dev:desktop": "turbo watch dev --filter=@teak/desktop",
    "lint": "turbo run lint",
    "pre-commit": "turbo run typecheck lint build --affected",
    "prepare": "simple-git-hooks || exit 0",
    "start": "turbo run start",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "clean": "turbo daemon clean && rm -rf node_modules/.cache && find . -name '.turbo' -type d -prune -exec rm -rf {} +"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run pre-commit"
  },
  "overrides": {
    "convex": "1.39.1",
    "convex-helpers": "0.1.118",
    "esbuild": "0.28.1",
    "expo-constants": "56.0.14",
    "expo-font": "56.0.5",
    "expo-linking": "56.0.11",
    "expo-web-browser": "56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "lru-cache": "5.1.1",
    "portless": "0.14.0",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.9.18",
    "ultracite": "7.8.3"
  },
  "trustedDependencies": [
    "@sentry/cli",
    "@swc/core",
    "@teak/extension",
    "spawn-sync"
  ]
}
