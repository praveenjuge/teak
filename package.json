{
  "name": "teak",
  "version": "1.0.35",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:raycast": "turbo run build --filter=./apps/raycast",
    "build:extension": "turbo run build --filter=@teak/extension",
    "dev": "turbo watch dev --filter=@teak/web --filter=@teak/convex",
    "dev:all": "turbo watch dev",
    "dev:convex": "turbo watch dev --filter=@teak/convex",
    "dev:docs": "turbo watch dev --filter=@teak/docs",
    "dev:api": "turbo watch dev --filter=@teak/api",
    "dev:raycast": "turbo watch dev --filter=./apps/raycast",
    "publish:raycast": "cd apps/raycast && bun run publish",
    "dev:extension": "turbo watch dev --filter=@teak/extension --filter=@teak/convex",
    "dev:mobile": "turbo watch dev --filter=@teak/mobile",
    "dev:web": "turbo watch dev --filter=@teak/web --filter=@teak/convex",
    "dev:desktop": "turbo watch dev --filter=@teak/desktop",
    "lint": "turbo run lint",
    "pre-commit": "turbo run typecheck lint build --affected",
    "prepare": "simple-git-hooks || exit 0",
    "start": "turbo run start",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "clean": "turbo daemon clean && rm -rf node_modules/.cache && find . -name '.turbo' -type d -prune -exec rm -rf {} +"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run pre-commit"
  },
  "overrides": {
    "convex": "1.38.0",
    "convex-helpers": "0.1.116",
    "expo-constants": "55.0.16",
    "expo-font": "55.0.7",
    "expo-linking": "55.0.15",
    "expo-web-browser": "55.0.15",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.9.8",
    "ultracite": "7.6.3"
  }
}
