{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": [
      "electron",
      "vite/client",
      "@electron-forge/plugin-vite/forge-vite-env"
    ]
  },
  "include": ["src/main"]
}
