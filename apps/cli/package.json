{
  "name": "teak-cli",
  "version": "1.0.53",
  "description": "Command-line client for Teak, the personal knowledge hub for saving and rediscovering ideas.",
  "type": "module",
  "bin": {
    "teak": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "teak",
    "cli",
    "knowledge-base",
    "bookmark-manager",
    "notes",
    "mcp",
    "api-client",
    "productivity"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target=node --format=esm --banner '#!/usr/bin/env node' && chmod +x dist/index.js",
    "test": "bun test src --coverage --dots",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@teak/convex": "workspace:*",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/praveenjuge/teak.git",
    "directory": "apps/cli"
  },
  "homepage": "https://teakvault.com/docs/cli",
  "bugs": {
    "url": "https://github.com/praveenjuge/teak/issues"
  },
  "author": "Praveen Juge <hello@praveenjuge.com>",
  "license": "MIT"
}
