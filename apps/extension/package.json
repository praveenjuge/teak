{
  "name": "@teak/extension",
  "description": "Teak - Your Personal Knowledge Hub. Save, organize, and rediscover web content, text selections, and ideas effortlessly.",
  "version": "1.0.56",
  "author": "Praveen Juge (hi@praveenjuge.com)",
  "homepage": "https://teakvault.com",
  "type": "module",
  "scripts": {
    "dev": "wxt --port 3003",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "test": "bun test __tests__ --coverage --dots",
    "typecheck": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@convex-dev/better-auth": "0.12.5",
    "@tailwindcss/vite": "^4.3.0",
    "@teak/convex": "workspace:*",
    "better-auth": "1.6.23",
    "convex": "^1.39.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "typescript": "^6.0.3",
    "wxt": "^0.20.26"
  }
}
