---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import DocsMobileNav from "../components/DocsMobileNav.astro";
import DocsSidebar from "../components/DocsSidebar.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogImage?: string;
  twitterCard?: string;
  keywords?: string;
  jsonLd?: object | object[];
  headings?: { depth: number; slug: string; text: string }[];
}

const { headings = [], ...rest } = Astro.props;
const currentPath = Astro.url.pathname;
---

<BaseLayout {...rest}>
  <Header />
  <div class="pt-20">
    <div class="mx-auto flex max-w-7xl">
      <!-- Sidebar -->
      <aside class="sticky top-20 hidden h-[calc(100vh-5rem)] w-64 shrink-0 overflow-y-auto border-r p-4 md:block">
        <DocsSidebar currentPath={currentPath} />
      </aside>

      <!-- Main content -->
      <main class="min-w-0 flex-1 px-6 py-8 md:px-12">
        <DocsMobileNav currentPath={currentPath} />
        <article class="prose prose-zinc max-w-none">
          <slot />
        </article>
      </main>

      <!-- Table of Contents -->
      {headings.length > 0 && (
        <aside class="sticky top-20 hidden h-[calc(100vh-5rem)] w-56 shrink-0 overflow-y-auto p-4 xl:block">
          <nav>
            <p class="mb-3 font-medium text-sm">On this page</p>
            <ul class="space-y-2 text-sm">
              {headings
                .filter((h) => h.depth <= 3)
                .map((heading) => (
                  <li style={`padding-left: ${(heading.depth - 2) * 0.75}rem`}>
                    <a
                      href={`#${heading.slug}`}
                      class="text-muted-foreground transition-colors hover:text-foreground"
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
            </ul>
          </nav>
        </aside>
      )}
    </div>
  </div>
</BaseLayout>
