---
import { ChevronDown } from "lucide-react";
import { docsNavItems, isDocsNavItemActive } from "../lib/docs-navigation";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const activeItem =
  docsNavItems.find((item) => isDocsNavItemActive(item.href, currentPath)) ??
  docsNavItems[0];
---

<div class="mb-6 md:hidden">
  <label class="mb-2 block font-medium text-sm" for="docs-mobile-nav">
    Docs
  </label>
  <div class="relative">
    <select
      class="h-11 w-full appearance-none rounded-lg border bg-background px-3 pr-10 font-medium text-sm text-foreground shadow-sm outline-none transition-colors focus:border-ring focus:ring-[3px] focus:ring-ring/50"
      data-docs-mobile-nav
      id="docs-mobile-nav"
    >
      {docsNavItems.map((item) => (
        <option selected={item.href === activeItem.href} value={item.href}>
          {item.title}
        </option>
      ))}
    </select>
    <ChevronDown className="pointer-events-none absolute top-1/2 right-3 size-4 -translate-y-1/2 text-muted-foreground" />
  </div>
</div>

<script>
  const select = document.querySelector<HTMLSelectElement>("[data-docs-mobile-nav]");
  select?.addEventListener("change", () => {
    if (select.value && select.value !== window.location.pathname) {
      window.location.href = select.value;
    }
  });
</script>
