---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import HomeLayout from "../../layouts/HomeLayout.astro";
import { authors, getAuthor } from "../../lib/authors";

export function getStaticPaths() {
  return Object.keys(authors).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const author = getAuthor(slug!);

if (!author) {
  return Astro.redirect("/404");
}

const entries = await getCollection("changelog");
const sortedEntries = entries.sort(
  (a: CollectionEntry<"changelog">, b: CollectionEntry<"changelog">) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<HomeLayout
  title={`${author.name} - Teak Team`}
  description={author.bio}
  canonical={`https://teakvault.com/authors/${author.id}`}
  ogTitle={`${author.name} - Teak Team`}
  ogDescription={author.bio}
  ogType="profile"
  ogImage={author.avatar}
  twitterCard="summary"
  keywords={`${author.name}, teak author, teak team, ${author.role.toLowerCase()}`}
>
  <div class="container mx-auto max-w-2xl px-4 py-12">
    <div class="mt-10 mb-12">
      <div class="mb-8 flex flex-col items-center text-center sm:flex-row sm:items-start sm:text-left">
        <img
          alt={author.name}
          class="mb-4 rounded-full sm:mr-6 sm:mb-0"
          height="120"
          src={author.avatar}
          width="120"
        />
        <div>
          <h1 class="mb-1 font-bold text-3xl tracking-tight md:text-4xl">
            {author.name}
          </h1>
          <p class="mb-3 font-medium text-lg text-primary">{author.role}</p>
          <p class="mb-4 text-muted-foreground">{author.bio}</p>
          <div class="flex flex-wrap justify-center gap-2 sm:justify-start">
            {author.social.twitter && (
              <a
                class="inline-flex shrink-0 items-center justify-center gap-2 whitespace-nowrap rounded-md font-medium text-sm border bg-background hover:bg-accent hover:text-accent-foreground h-8 gap-1.5 px-3"
                href={author.social.twitter}
                rel="noopener noreferrer"
                target="_blank"
              >
                Twitter
              </a>
            )}
            {author.social.github && (
              <a
                class="inline-flex shrink-0 items-center justify-center gap-2 whitespace-nowrap rounded-md font-medium text-sm border bg-background hover:bg-accent hover:text-accent-foreground h-8 gap-1.5 px-3"
                href={author.social.github}
                rel="noopener noreferrer"
                target="_blank"
              >
                GitHub
              </a>
            )}
            {author.social.website && (
              <a
                class="inline-flex shrink-0 items-center justify-center gap-2 whitespace-nowrap rounded-md font-medium text-sm border bg-background hover:bg-accent hover:text-accent-foreground h-8 gap-1.5 px-3"
                href={author.social.website}
                rel="noopener noreferrer"
                target="_blank"
              >
                Website
              </a>
            )}
          </div>
        </div>
      </div>

      <div class="border-t pt-8">
        <h2 class="mb-6 font-semibold text-xl">
          Changelog Updates ({sortedEntries.length})
        </h2>
        <div class="space-y-4">
          {sortedEntries.map((entry: CollectionEntry<"changelog">) => (
            <a
              class="block rounded-lg border bg-background p-4 transition-colors hover:border-primary/50 hover:bg-muted/50"
              href="/changelog"
            >
              <p class="mb-1 text-muted-foreground text-sm">
                {new Date(entry.data.date).toLocaleDateString("en-US", {
                  month: "long",
                  day: "numeric",
                  year: "numeric",
                })}
              </p>
              <h3 class="font-medium">{entry.data.title}</h3>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</HomeLayout>
