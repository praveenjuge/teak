---
import { getEntry, render } from "astro:content";
import DocsLayout from "../../layouts/DocsLayout.astro";
import {
  organizationSchema,
  buildArticleSchema,
  buildBreadcrumbSchema,
  SITE_URL,
} from "../../lib/jsonld";

const entry = await getEntry("docs", "index");
if (!entry) {
  return Astro.redirect("/404");
}

const { Content, headings } = await render(entry);

const articleSchema = buildArticleSchema({
  title: entry.data.title,
  description: entry.data.description,
  url: `${SITE_URL}/docs`,
});

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Home", url: SITE_URL },
  { name: "Docs", url: `${SITE_URL}/docs` },
]);
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  canonical="https://teakvault.com/docs"
  ogTitle={entry.data.title}
  ogDescription={entry.data.description}
  ogType="article"
  keywords={`teak, ${entry.data.title.toLowerCase()}, personal knowledge management, setup guide`}
  jsonLd={[organizationSchema, articleSchema, breadcrumbSchema]}
  headings={headings}
>
  <h1>{entry.data.title}</h1>
  {entry.data.description && <p class="text-lg text-muted-foreground mb-8">{entry.data.description}</p>}
  <Content />
</DocsLayout>
