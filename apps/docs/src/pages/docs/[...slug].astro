---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import DocsLayout from "../../layouts/DocsLayout.astro";
import { organizationSchema, SITE_URL } from "../../lib/jsonld";

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  return docs
    .filter((doc: CollectionEntry<"docs">) => doc.id !== "index")
    .map((doc: CollectionEntry<"docs">) => ({
      params: { slug: doc.id },
      props: { entry: doc },
    }));
}

interface Props {
  entry: CollectionEntry<"docs">;
}

const { entry } = Astro.props as Props;
const { Content, headings } = await render(entry);

const pageUrl = `${SITE_URL}/docs/${entry.id}`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": `${pageUrl}/#article`,
  headline: entry.data.title,
  description: entry.data.description,
  url: pageUrl,
  isPartOf: { "@id": `${SITE_URL}/#website` },
  author: { "@id": `${SITE_URL}/#organization` },
  publisher: { "@id": `${SITE_URL}/#organization` },
  image: `${SITE_URL}/hero-image.png`,
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: SITE_URL },
    { "@type": "ListItem", position: 2, name: "Docs", item: `${SITE_URL}/docs` },
    { "@type": "ListItem", position: 3, name: entry.data.title, item: pageUrl },
  ],
};
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  canonical={`https://teakvault.com/docs/${entry.id}`}
  ogTitle={entry.data.title}
  ogDescription={entry.data.description}
  ogType="article"
  keywords={`teak, ${entry.data.title.toLowerCase()}, personal knowledge management, setup guide`}
  jsonLd={[organizationSchema, articleSchema, breadcrumbSchema]}
  headings={headings}
>
  <h1>{entry.data.title}</h1>
  {entry.data.description && <p class="text-lg text-muted-foreground mb-8">{entry.data.description}</p>}
  <Content />
</DocsLayout>
